{
  "entities": {
    "Ticket": {
      "title": "Ticket",
      "description": "A support ticket from Splendid Technology",
      "type": "object",
      "properties": {
        "ticketNumber": { "type": "string" },
        "subject": { "type": "string" },
        "status": { "type": "string", "enum": ["Done", "In Progress", "Visit Scheduled", "Open"] },
        "visitDate": { "type": "string", "format": "date" },
        "contactName": { "type": "string" },
        "address": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ticketNumber", "subject", "status", "userId", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/tickets/{ticketId}": {
      "schema": "Ticket",
      "description": "Collection of vendor support tickets"
    }
  }
}
